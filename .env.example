# Root .env — Jira credentials + all secrets, shared by the agent and every board.
# Copy to .env and fill in real values. Non-secret per-board settings live in each
# <board>/config.toml (committed).

# ── Jira credentials (shared) ────────────────────────────────────────────────
JIRA_DOMAIN=your-tenant.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# ── Agent secrets ────────────────────────────────────────────────────────────
AGENT_KEY=your-agent-key
GCP_PROJECT=your-gcp-project
GOOGLE_APPLICATION_CREDENTIALS=./credentials/your-service-account.json
PIC_CONFIG_SHEET_ID=your-google-sheet-id

# ── Google Chat webhooks ─────────────────────────────────────────────────────
#GCHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/.../messages?key=...&token=...
GCHAT_REPORT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/.../messages?key=...&token=...

# ── Jira Automation webhooks (triage clone destinations) ─────────────────────
JIRA_WEBHOOK_PORTFOLIO=https://api-private.atlassian.com/automation/webhooks/jira/...
JIRA_WEBHOOK_BUG=https://api-private.atlassian.com/automation/webhooks/jira/...
JIRA_WEBHOOK_DEVOPS=https://api-private.atlassian.com/automation/webhooks/jira/...
JIRA_WEBHOOK_RNG_TASK=https://api-private.atlassian.com/automation/webhooks/jira/...
