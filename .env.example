# Root .env — Jira credentials, shared by the Game Status board.
# Copy to .env and fill in real values. Non-secret per-board settings live in
# game-status-analysis/config.toml (committed).

# ── Jira credentials (shared) ────────────────────────────────────────────────
JIRA_DOMAIN=your-tenant.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
